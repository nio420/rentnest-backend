model User {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  password     String
  phone        String?
  profilePhoto String?

  role   Role       @default(TENANT)
  status UserStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  properties     Property[]
  rentalRequests RentalRequest[]
  reviews        Review[]
  payments       Payment[]

  @@map("users")
}
